rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "robsonbatista3@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Media Validation
    function isValidMedia(data) {
      return data.media_type in ['movie', 'tv', 'anime'];
    }

    // Episode Validation
    function isValidEpisode(data) {
      return data.video_url is string && data.video_url.size() > 0;
    }

    // Custom Media Collection
    match /custom_media/{mediaId} {
      allow read: if true; // Public can read media
      allow create: if isAdmin() && isValidMedia(request.resource.data);
      allow update: if isAdmin() && isValidMedia(request.resource.data);
      allow delete: if isAdmin();

      match /episodes/{episodeId} {
        allow read: if true;
        allow create, update: if isAdmin() && isValidEpisode(request.resource.data);
        allow delete: if isSignedIn() && (request.auth.token.email == "robsonbatista3@gmail.com");
      }
    }

    // App Config
    match /app_config/settings {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
  }
}
